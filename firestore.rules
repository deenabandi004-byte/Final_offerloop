rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to get user tier.
    // Backend writes `subscriptionTier` (source of truth). `tier` is a legacy
    // fallback kept for users whose docs predate the migration. See CLAUDE.md
    // "Known inconsistency: tier vs subscriptionTier".
    function getUserTier(userId) {
      let userData = get(/databases/$(database)/documents/users/$(userId)).data;
      return userData.get('subscriptionTier', userData.get('tier', 'free'));
    }

    // Helper function to check if user has Pro or Elite tier
    function hasProOrEliteTier(userId) {
      let tier = getUserTier(userId);
      return tier == 'pro' || tier == 'elite';
    }
    
    // Users collection
    match /users/{userId} {
      // Users can read their own data
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // Users can update their own data EXCEPT backend-managed fields.
      //
      // Three classes of protected fields:
      //   1) tier/subscription — written only by Stripe webhook → backend
      //   2) credit accounting — atomically deducted server-side; client write
      //      would let a malicious user set `credits: 999999` to bypass paywalls
      //   3) ranking/personalization caches — derived from server-side
      //      computation, never user input; client write could spoof scoring
      //      or rank-bias via fake embeddings
      allow update: if request.auth != null && request.auth.uid == userId
        // (1) tier
        && !('tier' in request.resource.data.diff(resource.data).affectedKeys())
        && !('subscriptionTier' in request.resource.data.diff(resource.data).affectedKeys())
        && !('stripeSubscriptionId' in request.resource.data.diff(resource.data).affectedKeys())
        && !('stripeCustomerId' in request.resource.data.diff(resource.data).affectedKeys())
        // (2) credit accounting — `maxCredits` was already blocked; `credits`
        // (current balance) and reset timer were not
        && !('maxCredits' in request.resource.data.diff(resource.data).affectedKeys())
        && !('credits' in request.resource.data.diff(resource.data).affectedKeys())
        && !('lastCreditReset' in request.resource.data.diff(resource.data).affectedKeys())
        && !('alumniSearchesUsed' in request.resource.data.diff(resource.data).affectedKeys())
        && !('coffeeChatPrepsUsed' in request.resource.data.diff(resource.data).affectedKeys())
        && !('interviewPrepsUsed' in request.resource.data.diff(resource.data).affectedKeys())
        // (3) ranking + personalization caches
        && !('resumeEmbedding' in request.resource.data.diff(resource.data).affectedKeys())
        && !('resumeEmbeddingHash' in request.resource.data.diff(resource.data).affectedKeys())
        && !('jobFeedCache' in request.resource.data.diff(resource.data).affectedKeys())
        // (4) referral system — written only by backend (admin SDK)
        && !('referralCode' in request.resource.data.diff(resource.data).affectedKeys())
        && !('referredBy' in request.resource.data.diff(resource.data).affectedKeys())
        && !('referralQualifiedCount' in request.resource.data.diff(resource.data).affectedKeys())
        && !('referralRewardClaimed' in request.resource.data.diff(resource.data).affectedKeys())
        && !('referralRewardClaimedAt' in request.resource.data.diff(resource.data).affectedKeys())
        && !('referralRewardPendingAt' in request.resource.data.diff(resource.data).affectedKeys())
        && !('referralBannerDismissedAt' in request.resource.data.diff(resource.data).affectedKeys())
        && !('referralLaunchModalSeenAt' in request.resource.data.diff(resource.data).affectedKeys());
      
      // Users can create their own document on signup, but cannot preload referral
      // bookkeeping fields (admin SDK bypasses rules, so attribution still works).
      allow create: if request.auth != null && request.auth.uid == userId
        && !request.resource.data.keys().hasAny(['referralCode', 'referredBy', 'referralQualifiedCount', 'referralRewardClaimed', 'referralRewardClaimedAt', 'referralRewardPendingAt', 'referralBannerDismissedAt', 'referralLaunchModalSeenAt']);
      
      // Subcollections under users
      match /contacts/{contactId} {
        // Users can read/write their own contacts
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /firmSearches/{searchId} {
        // Users can read/write their own firm searches
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /searchHistory/{historyId} {
        // Users can read/write their own search history
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /exports/{exportId} {
        // Export operations require Pro/Elite tier
        allow create: if request.auth != null 
          && request.auth.uid == userId
          && hasProOrEliteTier(userId);
        
        // Users can read their own exports
        allow read: if request.auth != null && request.auth.uid == userId;
      }
      
      match /activity/{activityId} {
        // Users can read/write their own activity logs
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /goals/{goalId} {
        // Users can read/write their own goals
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /calendar_events/{eventId} {
        // Users can read/write their own calendar events
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // Recruiters (Hiring Manager Tracker)
      match /recruiters/{recruiterId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Manually-added companies on My Network (inline add-row UI)
      match /manual_firms/{firmId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // Notifications (outbox is a fixed doc: notifications/outbox)
      match /notifications/{notificationId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // Scout AI conversations
      match /scoutConversations/{convId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // Professional info (stored as subcollection doc e.g. professionalInfo/info by backend; frontend also uses field on user doc)
      match /professionalInfo/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // Coffee chat prep notes
      match /coffee-chat-preps/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // Interview prep notes
      match /interview-preps/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // Resume library
      match /resume_library/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // Resume scores
      match /resume_scores/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // Cover letter library
      match /cover_letter_library/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Agent settings (config)
      match /settings/{docId} {
        allow read: if request.auth != null && request.auth.uid == userId;
      }

      // Agent actions (live activity feed)
      match /agent_actions/{actionId} {
        allow read: if request.auth != null && request.auth.uid == userId;
      }

      // Agent cycles (cycle progress)
      match /agent_cycles/{cycleId} {
        allow read: if request.auth != null && request.auth.uid == userId;
      }

      // Agent jobs
      match /agent_jobs/{jobId} {
        allow read: if request.auth != null && request.auth.uid == userId;
      }

      // Agent companies
      match /agent_companies/{companyId} {
        allow read: if request.auth != null && request.auth.uid == userId;
      }

      // Referral bookkeeping — backend (admin SDK) only; clients cannot read or write
      match /referrals/{referredUid} {
        allow read, write: if false;
      }
    }
    
    // Feature flags: read-only for authenticated users, write-only via Admin SDK
    match /system/feature_flags {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // PDL Job Title Enrichment cache — server-only. Written by the pipeline
    // (Admin SDK bypasses rules). No client surface; client writes could
    // poison the cache and drain the 50k credit pool by forcing misses.
    match /job_title_enrichments/{slug} {
      allow read, write: if false;
    }

    // PDL credit usage counter — server-only. Powers the budget circuit
    // breaker in pdl_title_cache.py; clients must not be able to reset it.
    match /pdl_usage/{docId} {
      allow read, write: if false;
    }

    // Referral code lookup — backend (admin SDK) only.
    match /referralCodes/{code} {
      allow read, write: if false;
    }

    // Default: deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
