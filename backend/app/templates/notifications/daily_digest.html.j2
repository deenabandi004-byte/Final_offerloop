<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Your loop digest</title>
</head>
<body style="margin:0;padding:0;background:#FAFAF7;font-family:Georgia,'Times New Roman',serif;color:#1A1A1A;">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#FAFAF7;">
    <tr>
      <td align="center" style="padding:32px 16px;">
        <table role="presentation" width="600" cellpadding="0" cellspacing="0" border="0" style="max-width:600px;width:100%;background:#FFFFFF;">
          <tr>
            <td style="padding:40px 32px 24px 32px;">
              <h1 style="margin:0;font-family:Georgia,'Times New Roman',serif;font-style:italic;font-weight:400;font-size:26px;line-height:1.3;color:#1A1A1A;">
                Your loop found {{ items|length }} {{ "thing" if items|length == 1 else "things" }}.
              </h1>
            </td>
          </tr>

          {% for item in items %}
          <tr>
            <td style="padding:20px 32px;border-top:1px solid #E5E5E5;">
              <div style="font-family:Georgia,'Times New Roman',serif;font-size:16px;line-height:1.5;color:#1A1A1A;">
                <span style="font-weight:700;">{{ item.company }}</span>
                <span style="color:#1A1A1A;"> &middot; {{ item.title }}</span>
              </div>
              {% if item.context %}
              <div style="margin-top:6px;font-family:Georgia,'Times New Roman',serif;font-style:italic;font-size:14px;color:#555555;">
                {{ item.context }}
              </div>
              {% endif %}
              {% if item.loop_url %}
              <div style="margin-top:10px;">
                <a href="{{ item.loop_url }}" style="font-family:Georgia,'Times New Roman',serif;font-size:14px;color:#1A1A1A;text-decoration:underline;">View &rarr;</a>
              </div>
              {% endif %}
            </td>
          </tr>
          {% endfor %}

          <tr>
            <td style="padding:32px 32px 40px 32px;border-top:1px solid #E5E5E5;">
              <div style="font-family:'Courier New',Courier,monospace;font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:#888888;">
                Offerloop &middot; Not Forwarded.
              </div>
              <div style="margin-top:12px;font-family:Georgia,'Times New Roman',serif;font-size:12px;color:#888888;">
                <a href="{{ unsubscribe_url }}" style="color:#888888;text-decoration:underline;">Unsubscribe</a>
              </div>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
